{
  "ConnectionStrings": {
    "Default": "Server=(localdb)\\MSSQLLocalDB;Database=PropertyManagementDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "Database": {
    "UseInMemory": false
  },
  "Hangfire": {
    "UseInMemory": false
  },
  "Jwt": {
    "Issuer": "PropertyManagement",
    "Audience": "PropertyManagement.Clients",
    "SigningKey": "PropertyManagementDevelopmentSigningKey_ChangeMe_Min32Chars_!",
    "AccessTokenMinutes": 120,
    "RefreshTokenDays": 14
  },
  "Storage": {
    "LocalRoot": "App_Data/documents"
  },
  "Pms": {
    "RentManager": {
      "Mode": "Auto"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Hangfire": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
