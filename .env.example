###############################################################################
#  Property Management Platform — local docker-compose environment overrides  #
#                                                                             #
#  Copy this file to .env (sibling of docker-compose.yml) and fill in values  #
#  before running `docker compose up`. None of these are required when using  #
#  the in-memory development build (`dotnet run` from the backend folder).    #
###############################################################################

# ── SQL Server ────────────────────────────────────────────────────────────
# Strong password (>= 8 chars, mix of upper/lower/digits/symbols).
MSSQL_SA_PASSWORD=PropertyMgmt!Strong#2025
MSSQL_DATABASE=PropertyManagementDb

# ── JWT ───────────────────────────────────────────────────────────────────
# Issuer + audience must match between the API and any third-party verifiers.
JWT_ISSUER=PropertyManagement
JWT_AUDIENCE=PropertyManagement.Clients

# >= 32 characters. ROTATE this in production. Treat it like a database password.
JWT_SIGNING_KEY=ChangeMeInProduction_UseSecretsManager_AtLeast32Chars!
